meta {
  name: Create Settlement
  type: http
  seq: 2
}

post {
  url: {{base_url}}/events/{{event_guid}}/settlements
  body: json
  auth: bearer
}

headers {
  X-EventUser-GUID: {{eventuser_guid}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "recipient_id": 2,
    "currency_id": 1,
    "amount": 25.00,
    "description": "Reimbursement"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("settlement_guid", res.body.guid);
  }
}
