meta {
  name: WebAuthn Authenticate Verify
  type: http
  seq: 8
}

post {
  url: {{base_url}}/auth/webauthn/authenticate/verify
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "session_id": "challenge-guid",
    "credential": {}
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.token);
  }
}
